# Create a fine-grained GitHub token with read-only access needed for starred repo and search API calls.
# PowerShell local use:
#   $env:GH_TOKEN="github_pat_..."
# Or copy this file to .env and set the value there.
GH_TOKEN=

# Optional override. Defaults to https://api.github.com
GITHUB_API_BASE_URL=https://api.github.com
